[Unit]
Description=Tetris Backend Leaderboard
After=network.target

[Service]
WorkingDirectory=/srv/tetris_api
EnvironmentFile=-/srv/tetris_api/.env
ExecStart=/srv/tetris_api/.venv/bin/uvicorn main:app \
  --host 127.0.0.1 \
  --port 7898

Restart=always
RestartSec=3
User=www-data
Group=www-data

[Install]
WantedBy=multi-user.target
